# Copie este arquivo para .env.server e preencha com seus valores reais.
# O arquivo .env.server está no .gitignore e NUNCA deve ser commitado.

# Token da brapi.dev — obtenha em https://brapi.dev/dashboard
BRAPI_TOKEN=seu_token_aqui

# Chave da HG Brasil — obtenha em https://console.hgbrasil.com
HG_BRASIL_KEY=sua_chave_aqui

# Porta do servidor (padrão: 3001)
PORT=3001

# TTL do cache de cotações em milissegundos (padrão: 60000 = 1 minuto)
QUOTE_CACHE_TTL_MS=60000

# Origem permitida para CORS (padrão: http://localhost:5173)
ALLOWED_ORIGIN=http://localhost:5173

# Host de bind do servidor (padrão: 0.0.0.0)
# Em produção, usar 127.0.0.1 para não expor a porta diretamente na internet
HOST=127.0.0.1
